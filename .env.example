# Live analytics — recommended for production (accurate global counts across regions).
# Without these, the API uses in-memory counts per server instance (fine for local dev).
# Add Upstash Redis: Vercel → Storage → Redis, or https://vercel.com/marketplace?category=storage&search=redis
#
# Keys are scoped per Vercel deployment (VERCEL_DEPLOYMENT_ID), so each new deploy starts from 0.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional overrides for the footer stats when Redis is not configured (defaults are 0):
# NEXT_PUBLIC_ANALYTICS_VISITORS=0
# NEXT_PUBLIC_ANALYTICS_VISITS=0
# NEXT_PUBLIC_ANALYTICS_PAGE_VIEWS=0

# Noupe AI — optional override (default embed is set in app/layout.tsx):
# NEXT_PUBLIC_NOUPE_SCRIPT_URL=https://www.noupe.com/embed/your-id.js

# Contact form (Resend + Supabase)
RESEND_API_KEY=
# Optional, if you have a verified domain on Resend:
# RESEND_FROM="Caleb <hello@yourdomain.com>"
RESEND_FROM="Caleb <onboarding@resend.dev>"
CONTACT_TO_EMAIL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=
