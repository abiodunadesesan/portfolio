# Live analytics (optional). Add Upstash Redis from Vercel → Storage → Redis, then paste:
# https://vercel.com/marketplace?category=storage&search=redis
#
# Counters are stored per Vercel deployment (VERCEL_DEPLOYMENT_ID), so each new production
# deploy starts from 0. Without Redis, the footer shows 0 unless you set overrides below.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional overrides for the footer stats when Redis is not configured (defaults are 0):
# NEXT_PUBLIC_ANALYTICS_VISITORS=0
# NEXT_PUBLIC_ANALYTICS_VISITS=0
# NEXT_PUBLIC_ANALYTICS_PAGE_VIEWS=0
